{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://getphios.com/schemas/book-architecture-manifest.schema.json",
  "title":"PHI OS Architecture-Only Book Manifest",
  "type":"object",
  "required":["manifest_version","book_id","series_id","volume","status","canonical_title","content_status","parts","figures","publication_version"],
  "properties":{
    "book_id":{"type":"string","pattern":"^phios-volume-[1-3]$"},
    "volume":{"type":"integer","minimum":1,"maximum":3},
    "status":{"enum":["draft","content-complete","frozen","published"]},
    "content_status":{"enum":["architecture-only","content-complete"]},
    "parts":{"type":"array","minItems":1,"items":{"type":"object","required":["id","number","title","status","chapters"]}},
    "figures":{"type":"array"}
  }
}


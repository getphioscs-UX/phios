{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://getphios.com/schemas/book-manifest.schema.json",
  "title": "PHI OS Book Manifest",
  "type": "object",
  "required": ["manifest_version", "book_id", "volume", "status", "canonical_title", "parts", "grammar", "figure_count"],
  "properties": {
    "manifest_version": {"type": "string"},
    "book_id": {"type": "string", "pattern": "^phios-volume-[0-9]+$"},
    "volume": {"type": "integer", "minimum": 1},
    "status": {"enum": ["draft", "content-complete", "frozen", "published"]},
    "canonical_title": {"$ref": "#/$defs/bilingual"},
    "parts": {"type": "array", "items": {"type": "object", "required": ["id", "number", "title", "purpose", "figures"]}},
    "grammar": {"type": "object"},
    "figure_count": {"type": "integer", "minimum": 0}
  },
  "$defs": {
    "bilingual": {
      "type": "object",
      "required": ["zh-Hans", "en"],
      "properties": {"zh-Hans": {"type": "string"}, "en": {"type": "string"}},
      "additionalProperties": false
    }
  }
}


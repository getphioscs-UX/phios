{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://getphios.com/schemas/concepts.schema.json",
  "type":"object",
  "required":["registry_version","status_definitions","concepts"],
  "properties":{
    "registry_version":{"type":"string"},
    "concepts":{"type":"array","minItems":1,"items":{"type":"object","required":["id","zh-Hans","en","status","definition","part"],"properties":{"id":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"},"status":{"enum":["stable","provisional","deprecated","narrative-only"]},"part":{"type":"integer","minimum":0,"maximum":14}}}}
  }
}


{
  "registry_version": "1.1.0",
  "status_definitions": {
    "stable": "第一册已给出稳定定义；标识符、中英文名称及核心含义不得任意修改。",
    "provisional": "第一册已建立概念，但后续册可以扩展边界；现阶段必须使用登记名称。",
    "narrative-only": "可用于解释或比喻，不得成为数据字段、分类或 API 枚举。",
    "deprecated": "旧称；只能用于迁移与搜索，不得生成到新内容。"
  },
  "concepts": [
    {"id":"reality","zh-Hans":"现实","en":"Reality","status":"stable","definition":"并非静止物体，而是持续组织、运行、反馈、重组并延续自身的过程。","part":0},
    {"id":"runtime","zh-Hans":"运行","en":"Runtime","status":"stable","definition":"现实进入载体之后，在时间、资源、约束与反馈之中持续发生的组织过程。","part":0,"grammar":"G7"},
    {"id":"reality_grammar","zh-Hans":"现实语法","en":"Reality Grammar","status":"stable","definition":"描述现实从差异到持续所反复经过的十六阶段生成逻辑。","part":0},
    {"id":"difference","zh-Hans":"差异","en":"Difference","status":"stable","definition":"现实得以出现的最初可区分状态。","part":1,"grammar":"G1"},
    {"id":"constraint","zh-Hans":"约束","en":"Constraint","status":"stable","definition":"对可能性进行裁剪，使差异获得可持续方向的机制。","part":1,"grammar":"G2"},
    {"id":"structure","zh-Hans":"结构","en":"Structure","status":"stable","definition":"差异在约束下形成的可持续关系组织。","part":1,"grammar":"G3"},
    {"id":"field","zh-Hans":"场域","en":"Field","status":"stable","definition":"结构持续连接后形成、能够影响其中可能性的作用范围。","part":1,"grammar":"G4"},
    {"id":"coordinate","zh-Hans":"坐标","en":"Coordinate","status":"provisional","definition":"现实在结构、关系与方向网络中获得的可读取位置。","part":1},
    {"id":"navigation","zh-Hans":"现实导航","en":"Reality Navigation","status":"stable","definition":"基于现实位置、状态、限制、方向与证据进行持续定位和修正的过程。","part":1},
    {"id":"projection","zh-Hans":"投影","en":"Projection","status":"stable","definition":"复杂现实经过接口筛选、压缩与组织后进入体验层的形式；不等同幻觉或错误。","part":2},
    {"id":"projection_surface","zh-Hans":"投影表面","en":"Projection Surface","status":"provisional","definition":"现实得以呈现并被读取的界面层。","part":2},
    {"id":"projection_compression","zh-Hans":"投影压缩","en":"Projection Compression","status":"provisional","definition":"现实进入有限感知与表达之前被筛选和简化的过程。","part":2},
    {"id":"meaning","zh-Hans":"意义","en":"Meaning","status":"provisional","definition":"投影被解释、估值并与既有模型连接后形成的重要性结构。","part":2},
    {"id":"shared_reality","zh-Hans":"共同现实","en":"Shared Reality","status":"provisional","definition":"多个系统透过投影、协调与强化共同维持的现实版本。","part":2},
    {"id":"synthetic_projection","zh-Hans":"合成投影","en":"Synthetic Projection","status":"provisional","definition":"由人工系统参与筛选、生成、排序或传播而形成的投影。","part":2},
    {"id":"temporal_medium","zh-Hans":"时间介质","en":"Temporal Medium","status":"provisional","definition":"使状态能够排序、激活、持续与结束的运行条件。","part":3},
    {"id":"activation","zh-Hans":"激活","en":"Activation","status":"stable","definition":"时间与条件打开现实进入运行的入口。","part":3,"grammar":"G5"},
    {"id":"runtime_capability","zh-Hans":"运行能力","en":"Runtime Capability","status":"provisional","definition":"现实为定位、理解、表达、资源、执行、关系、生存与推进所调用的能力。","part":3},
    {"id":"runtime_driver","zh-Hans":"运行驱动","en":"Runtime Driver","status":"provisional","definition":"使现实优先回应特定方向、压力或需要的驱动力。","part":3},
    {"id":"motion","zh-Hans":"运动","en":"Motion","status":"provisional","definition":"状态在承载、启动、渗透、流动、分化、定界与交换等原型中发生的变化。","part":3},
    {"id":"runtime_state","zh-Hans":"运行状态","en":"Runtime State","status":"stable","definition":"现实在特定时间、条件、载体与运行网络中形成的当前组织状态。","part":3},
    {"id":"feedback","zh-Hans":"反馈","en":"Feedback","status":"stable","definition":"运行结果返回系统并影响下一轮现实形成的过程。","part":3,"grammar":"G12"},
    {"id":"settlement","zh-Hans":"沉淀","en":"Settlement","status":"stable","definition":"反馈逐渐成为下一轮现实的稳定基础。","part":3,"grammar":"G13"},
    {"id":"reconfiguration","zh-Hans":"重组","en":"Reconfiguration","status":"stable","definition":"既有结构在新条件下重新组织。","part":3,"grammar":"G14"},
    {"id":"emergence","zh-Hans":"涌现","en":"Emergence","status":"stable","definition":"重组之后出现无法由单一局部独立解释的新组织。","part":3,"grammar":"G15"},
    {"id":"continuity","zh-Hans":"持续","en":"Continuity","status":"stable","definition":"现实模式跨越时间、状态或载体继续运行的能力。","part":3,"grammar":"G16"},
    {"id":"carrier","zh-Hans":"载体","en":"Carrier","status":"stable","definition":"使现实能够进入具体生命或系统并持续运行的承载结构。","part":4,"grammar":"G6"},
    {"id":"carrier_compression","zh-Hans":"载体压缩","en":"Carrier Compression","status":"provisional","definition":"现实进入有限载体时被转换为可承载配置的过程。","part":4},
    {"id":"reality_initialization_state","zh-Hans":"现实初始化状态","en":"Reality Initialization State","abbreviation":"RIS","status":"stable","definition":"生命开始运行时，由初始条件、时间、身体与配置共同形成的基础运行状态；不是固定命运。","part":4},
    {"id":"runtime_medium","zh-Hans":"运行介质","en":"Runtime Medium","status":"provisional","definition":"光、空气、水、食物、声音、温度与空间等使现实进入并调节生命运行的条件。","part":4},
    {"id":"carrier_stability","zh-Hans":"载体稳定","en":"Carrier Stability","status":"provisional","definition":"载体在变化中维持足够完整与协调以继续运行的能力。","part":4},
    {"id":"runtime_maintenance","zh-Hans":"运行维持","en":"Runtime Maintenance","status":"provisional","definition":"载体透过恢复、调节与协调维持连续运行的过程。","part":4},
    {"id":"runtime_drift","zh-Hans":"运行漂移","en":"Runtime Drift","status":"provisional","definition":"长期运行在压力、噪声、成本或反馈失配下逐渐偏离原有稳定范围。","part":4},
    {"id":"experience","zh-Hans":"体验","en":"Experience","status":"stable","definition":"现实进入意识并成为主体可感受内容的状态。","part":5,"grammar":"G8"},
    {"id":"awareness","zh-Hans":"觉察","en":"Awareness","status":"provisional","definition":"体验进入可被意识辨认与观察的范围。","part":5},
    {"id":"self_model","zh-Hans":"自我模型","en":"Self-Model","status":"provisional","definition":"意识对自身连续性、位置、边界与身份所形成的压缩模型。","part":5},
    {"id":"emotion","zh-Hans":"情绪","en":"Emotion","status":"provisional","definition":"意识对状态、预测、价值与行动准备形成的体验性信号。","part":5},
    {"id":"expression","zh-Hans":"表达","en":"Expression","status":"stable","definition":"体验开始以语言、行为、媒介或沉默向外显现。","part":5,"grammar":"G9"},
    {"id":"agency","zh-Hans":"行动","en":"Agency","status":"stable","definition":"表达进入选择、决定、责任与承诺后对现实产生影响的阶段。","part":5,"grammar":"G10"},
    {"id":"identity","zh-Hans":"身份","en":"Identity","status":"stable","definition":"持续行动与反馈沉淀形成、并继续影响理解和选择的稳定组织。","part":5,"grammar":"G11"},
    {"id":"conscious_continuity","zh-Hans":"意识连续性","en":"Conscious Continuity","status":"provisional","definition":"体验、自我模型、意义、表达与身份跨越时间保持可整合关系的能力。","part":5}
  ]
}

